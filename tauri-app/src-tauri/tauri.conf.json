{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Heliox-OS",
  "version": "0.7.1",
  "identifier": "com.helioxos.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix ./ui run dev",
    "beforeBuildCommand": "npm --prefix ./ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "Heliox-OS",
        "width": 700,
        "height": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:* ws://localhost:* http://localhost:*; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; media-src 'self' mediastream:; img-src 'self' blob: data:;"
    }
  },
  "plugins": {
    "clipboard-manager": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["python3 (>= 3.11)", "python3-pip"]
      }
    }
  }
}
